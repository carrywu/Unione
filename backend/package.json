    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "ali-oss": "^6.0.0",
    "axios": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "express": "4.22.1",
    "ioredis": "^5.0.0",
    "mysql2": "^3.0.0",
