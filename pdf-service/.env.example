DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
MAX_VISUAL_ELEMENTS_PER_PAGE=3

# PDF layout extractor:
# - pymupdf: current lightweight extractor
# - mineru: use MinerU CLI first, then fallback unless MINERU_STRICT=true
# - auto: use MinerU when the CLI is installed, otherwise PyMuPDF
PDF_LAYOUT_ENGINE=pymupdf
MINERU_BIN=mineru
MINERU_BACKEND=pipeline
MINERU_METHOD=auto
MINERU_LANG=ch
MINERU_TIMEOUT_SECONDS=900
MINERU_STRICT=false
