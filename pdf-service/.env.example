DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
MAX_VISUAL_ELEMENTS_PER_PAGE=3

# Optional visual AI correction layer. Disabled by default; parsing works without
# DASHSCOPE_API_KEY and skips this layer when the key is missing.
ENABLE_VISION_AI=false
VISION_AI_PROVIDER=qwen-vl
QWEN_VL_MODEL=qwen-vl-plus
VISION_AI_TIMEOUT_SECONDS=60
VISION_AI_MAX_RETRIES=2
VISION_AI_CONFIDENCE_THRESHOLD=0.75

# PDF layout extractor:
# - pymupdf: current lightweight extractor
# - mineru: use MinerU CLI first, then fallback unless MINERU_STRICT=true
# - auto: use MinerU when the CLI is installed, otherwise PyMuPDF
PDF_LAYOUT_ENGINE=pymupdf
MINERU_BIN=mineru
MINERU_BACKEND=pipeline
MINERU_METHOD=auto
MINERU_LANG=ch
MINERU_TIMEOUT_SECONDS=900
MINERU_STRICT=false
